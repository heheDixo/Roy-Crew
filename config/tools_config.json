{
  "nmap": {
    "description": "Network discovery and port scanning",
    "command": "nmap",
    "args_template": "{flags} {target}",
    "default_flags": "-sT -sV",
    "requires_root": false
  },
  "gobuster": {
    "description": "Directory brute-forcing",
    "command": "gobuster",
    "args_template": "dir -u {target} -w {wordlist} {flags}",
    "default_flags": "-t 50",
    "default_wordlist": "knowledge/wordlists/common.txt",
    "requires_root": false
  },
  "ffuf": {
    "description": "Fast web fuzzer",
    "command": "ffuf",
    "args_template": "-u {target}/FUZZ -w {wordlist} {flags}",
    "default_flags": "-c",
    "requires_root": false
  },
  "httpx": {
    "description": "HTTP probing toolkit",
    "command": "/opt/homebrew/bin/httpx",
    "args_template": "-u {target} {flags}",
    "default_flags": "-silent -status-code",
    "requires_root": false
  }
  ,
  "katana": {
    "description": "Fast web crawler for endpoint discovery",
    "command": "/opt/homebrew/bin/katana",
    "args_template": "-u {target} {flags}",
    "default_flags": "-d 3 -silent",
    "requires_root": false
  },
  "nuclei": {
    "description": "Template-based vulnerability scanner",
    "command": "/opt/homebrew/bin/nuclei",
    "args_template": "-u {target} {flags}",
    "default_flags": "-severity critical,high,medium -no-interactsh -silent",
    "requires_root": false
  }
}
