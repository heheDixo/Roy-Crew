{
  "servers": [
    {
      "name": "FFUF Fuzzer",
      "params": {
        "command": "npx",
        "args": [
          "-y",
          "gc-ffuf-mcp"
        ],
        "env": {
          "FFUF_PATH": "/opt/homebrew/bin/ffuf"
        }
      },
      "cache_tools_list": true
    },
    {
      "name": "Nmap Scanner",
      "params": {
        "command": "npx",
        "args": [
          "-y",
          "gc-nmap-mcp"
        ],
        "env": {
          "NMAP_PATH": "/opt/homebrew/bin/nmap"
        }
      },
      "cache_tools_list": true
    },
    {
      "name": "Katana",
      "params": {
        "command": "npx",
        "args": [
          "-y",
          "gc-katana-mcp"
        ],
        "env": {
          "KATANA_PATH": "/opt/homebrew/bin/katana"
        }
      },
      "cache_tools_list": true
    },
    {
      "name": "Nuclei Scanner",
      "params": {
        "command": "npx",
        "args": [
          "-y",
          "gc-nuclei-mcp"
        ],
        "env": {
          "NUCLEI_PATH": "/opt/homebrew/bin/nuclei"
        }
      },
      "cache_tools_list": true
    }
  ]
}